# Vaultwarden environment.
# Copy to .env on the ThinkCentre and fill in. Never commit .env.

# Argon2 hash of the admin token. NOT the raw token.
# Generate the hash:
#   docker run --rm -it vaultwarden/server:1.35.8-alpine /vaultwarden hash
# Paste the resulting "$argon2id$..." string (no quotes needed when shell-safe;
# wrap in single quotes if it contains characters Docker Compose interprets).
# Store the RAW token in 1Password under "Vaultwarden Admin".
ADMIN_TOKEN='REPLACE_WITH_ARGON2_HASH'

# Open registrations. Keep false in steady state. Flip to true only briefly
# when adding a new family member, then set back to false.
SIGNUPS_ALLOWED=false

# Allow already-registered admins to invite users without opening signups.
INVITATIONS_ALLOWED=true
