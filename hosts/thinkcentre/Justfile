base := home_directory() / "dotfiles/hosts/thinkcentre"

default: rebuild

# Rebuild NixOS from flake
rebuild: link
    sudo nixos-rebuild switch --flake ~/dotfiles/hosts/thinkcentre

# Create ~/service symlinks for all services with a docker-compose.yml.
# Also creates ~/Justfile convenience link.
# Runs automatically before rebuild and after webhook pull.
link:
    #!/usr/bin/env bash
    set -euo pipefail
    for dir in {{base}}/*/; do
      [ -f "$dir/docker-compose.yml" ] || continue
      name=$(basename "$dir")
      target="$HOME/$name"
      if [ -L "$target" ]; then
        continue
      elif [ -e "$target" ]; then
        echo "WARNING: ~/$name exists and is not a symlink, skipping"
        continue
      fi
      ln -s "$dir" "$target"
      echo "linked ~/$name"
    done
    [ -L "$HOME/Justfile" ] || [ -e "$HOME/Justfile" ] || ln -s "{{base}}/Justfile" "$HOME/Justfile"

# Show running containers
status:
    docker ps --format "table {{{{.Names}}}}\t{{{{.Status}}}}\t{{{{.Ports}}}}" | sort

# View container logs
logs name:
    docker logs -f --tail 100 {{name}}

# Restart a container
restart name:
    docker restart {{name}}

# Start Windows gaming VM (takes over GPU)
game:
    virsh start win11

# Stop Windows gaming VM (returns GPU to host)
stop-game:
    virsh shutdown win11
# webhook-test
