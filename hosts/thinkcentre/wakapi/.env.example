# Wakapi secrets - actual values go in .env (gitignored, not Syncthing-synced).
#
# WAKAPI_PASSWORD_SALT is CRITICAL: must match the value the existing DB was
# created with. Without this exact salt, all stored password hashes are
# unusable and no user can log in.
# Recovery: 1Password -> "Wakapi password salt"

WAKAPI_PASSWORD_SALT=replace-me-from-1password
