# ankiweb.net credentials per profile
# These get baked into each profile during one-time VNC setup;
# kept here so the credentials are version-controlled in your password manager
# and easy to re-apply if the data volume is wiped.
ANKI_CHRIS_USER=you@example.com
ANKI_CHRIS_PASS=changeme
ANKI_WIFE_USER=wife@example.com
ANKI_WIFE_PASS=changeme

# Telegram user IDs (from @userinfobot). Used by the openclaw skill to
# route inbound messages to the right Anki profile.
TG_USER_ID_CHRIS=000000000
TG_USER_ID_WIFE=000000000

# API keys for media generation. Used by the openclaw skill, not the headless container.
GEMINI_API_KEY=
GOOGLE_CLOUD_API_KEY=

# Optional: VNC password for one-time profile setup.
# Only used when QT_QPA_PLATFORM=vnc (see compose file).
VNC_PASSWORD=changeme
