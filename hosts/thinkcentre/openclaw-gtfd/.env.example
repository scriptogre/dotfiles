# OpenClaw GTFD Bot - cp .env.example .env

# Pinned to 2026.3.13 (local tag). Do NOT use :latest - 2026.4.x has 12s+ startup bloat.
OPENCLAW_IMAGE=openclaw:2026.3.13-local

# Auto-generate: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# @BotFather on Telegram > /newbot (create a SEPARATE bot for GTFD)
TELEGRAM_BOT_TOKEN=

# https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=

# https://console.groq.com/keys (voice transcription fallback)
GROQ_API_KEY=

# https://console.deepgram.com (primary voice transcription - Romanian support)
DEEPGRAM_API_KEY=

# CalDAV (Synology Calendar)
CALDAV_URL=https://calendar.christiantanul.com/caldav
CALDAV_USER=
CALDAV_PASS=
