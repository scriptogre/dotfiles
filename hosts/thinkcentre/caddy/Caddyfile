# SpacetimeDB / Hyperspace
# - - - - - - - - - - - - -

game.christiantanul.com {
    import cf-tls
    header Cross-Origin-Opener-Policy "same-origin"
    header Cross-Origin-Embedder-Policy "require-corp"

    @stdb path /v1/*
    handle @stdb {
        reverse_proxy 192.168.0.12:3000
    }

    handle {
        root * /srv/game
        file_server
    }

    encode gzip
}

hyperspace.christiantanul.com {
    import cf-tls
    reverse_proxy spacetimedb:3000
}

# Anki bot — public access ONLY for /media/* (image + audio served as static files
# referenced from flashcards). All API endpoints stay private on the proxy network.
anki-media.christiantanul.com {
    import cf-tls
    @media path /media/*
    handle @media {
        reverse_proxy anki-bot:8080
    }
    handle {
        respond 404
    }
}

