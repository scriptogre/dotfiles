{
    email contact@christiantanul.com
    acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
}

(lan-only) {
  @denied {
    not client_ip private_ranges  # LAN
    not client_ip 100.64.0.0/10   # Tailscale
  }
  abort @denied
}

