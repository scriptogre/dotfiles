{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "models": {
        "anthropic/claude-sonnet-4-6": {
          "alias": "sonnet",
          "params": {
            "cacheRetention": "short"
          }
        }
      },
      "workspace": "/home/node/.openclaw/workspace",
      "bootstrapMaxChars": 20000,
      "bootstrapTotalMaxChars": 150000,
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "30m"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "30m"
      }
    },
    "list": [
      {
        "id": "polish",
        "workspace": "/home/node/.openclaw/workspace"
      }
    ]
  },
  "tools": {
    "exec": {
      "security": "allowlist",
      "safeBins": [
        "curl"
      ],
      "safeBinProfiles": {
        "curl": {}
      }
    },
    "media": {
      "audio": {
        "enabled": true,
        "models": [
          {
            "provider": "groq"
          }
        ],
        "echoTranscript": true,
        "echoFormat": "> {transcript}"
      }
    }
  },
  "bindings": [
    {
      "agentId": "polish",
      "match": {
        "channel": "telegram"
      }
    }
  ],
  "messages": {
    "tts": {
      "auto": "off",
      "provider": "openai",
      "openai": {
        "baseUrl": "http://anki-bot:8080/v1",
        "model": "gemini-tts",
        "voice": "Kore"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 1,
    "retry": {
      "maxAttempts": 2,
      "backoffMs": [
        60000,
        120000
      ]
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": [
        "1351597714"
      ],
      "groupAllowFrom": [
        "1351597714"
      ],
      "groupPolicy": "allowlist",
      "streaming": "partial"
    }
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    },
    "auth": {
      "mode": "token",
      "token": ""
    }
  }
}