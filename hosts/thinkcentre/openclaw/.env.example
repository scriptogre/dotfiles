# OpenClaw - cp .env.example .env

OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_TZ=Europe/Bucharest

# Auto-generate: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_HOOKS_TOKEN=

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# @BotFather on Telegram > /newbot
TELEGRAM_BOT_TOKEN=

# https://hevy.com/settings > Developer
HEVY_API_KEY=

# https://console.groq.com/keys (voice transcription)
GROQ_API_KEY=

# https://platform.openai.com/api-keys (voice replies, STT fallback)
OPENAI_API_KEY=

# Auto-generated
HEALTHCLAW_API_KEY=

# https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=
